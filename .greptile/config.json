{
  "strictness": 2,
  "triggerOnUpdates": true,
  "triggerOnDrafts": false,
  "statusCheck": true,
  "commentTypes": ["logic", "syntax", "style"],
  "includeBranches": ["main", "next"],
  "excludeAuthors": [
    "dependabot[bot]",
    "renovate[bot]",
    "pre-commit-ci[bot]",
    "github-actions[bot]",
    "allcontributors[bot]",
    "better-release[bot]"
  ],
  "ignorePatterns": "**/pnpm-lock.yaml\n**/__snapshots__/**\n.changeset/*.md\n**/drizzle/meta/**",
  "context": {
    "repos": [
      "clearance/@clearance/call",
      "clearance/better-fetch",
      "clearance/utils"
    ]
  }
}
