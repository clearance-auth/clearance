{
  "name": "@clearance/sso",
  "version": "1.6.23",
  "description": "SSO plugin for Clearance",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/clearance-auth/clearance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clearance-auth/clearance.git",
    "directory": "packages/sso"
  },
  "author": "Bereket Engida",
  "keywords": [
    "sso",
    "auth",
    "saml",
    "oauth",
    "oidc",
    "openid",
    "openid connect",
    "single sign on",
    "typescript",
    "clearance"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ]
    }
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "jose": "^6.1.3",
    "samlify": "^2.13.1",
    "tldts": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clearance/core": "workspace:*",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@clearance/runtime": "workspace:*",
    "@clearance/call": "workspace:^",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "oauth2-mock-server": "^8.2.2",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@clearance/core": "workspace:^",
    "@clearance/utils": "workspace:^",
    "@better-fetch/fetch": "catalog:",
    "@clearance/runtime": "workspace:^",
    "@clearance/call": "workspace:^"
  }
}
