{
  "name": "@clearance/scim",
  "version": "1.6.23",
  "description": "SCIM plugin for Clearance",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/clearance-auth/clearance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clearance-auth/clearance.git",
    "directory": "packages/scim"
  },
  "author": "Jonathan Samines",
  "keywords": [
    "auth",
    "scim",
    "typescript",
    "clearance"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ]
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clearance/core": "workspace:*",
    "@clearance/sso": "workspace:*",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@clearance/core": "workspace:^",
    "@clearance/utils": "workspace:^",
    "@clearance/runtime": "workspace:^",
    "@clearance/call": "workspace:^"
  }
}
