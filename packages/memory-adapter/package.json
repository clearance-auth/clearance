{
  "name": "@clearance/memory-adapter",
  "version": "1.6.23",
  "description": "Memory adapter for Clearance",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/clearance-auth/clearance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clearance-auth/clearance.git",
    "directory": "packages/memory-adapter"
  },
  "keywords": [
    "auth",
    "memory",
    "adapter",
    "typescript",
    "clearance"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "peerDependencies": {
    "@clearance/core": "workspace:^",
    "@clearance/utils": "workspace:^"
  },
  "devDependencies": {
    "@clearance/core": "workspace:*",
    "@clearance/utils": "workspace:^",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
