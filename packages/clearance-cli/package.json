{
  "name": "@clearance/cli",
  "version": "0.1.0",
  "description": "Clearance CLI — operate auth projects, enterprise connections, migrations, and deploys",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "clearance": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
		"build": "tsc -p tsconfig.json && node scripts/stage-ops.mjs && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --maxWorkers=1",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clearance/management": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
