{
  "name": "@clearance/api",
  "version": "0.1.0",
  "description": "Clearance management API",
  "type": "module",
  "license": "MIT",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clearance/management": "workspace:*",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.23.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
