{
  "name": "@clearance/api",
  "version": "0.2.1",
  "description": "Clearance management API",
  "type": "module",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/clearance-auth/clearance", "directory": "packages/clearance-api" },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --maxWorkers=1",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clearance/management": "workspace:*",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
